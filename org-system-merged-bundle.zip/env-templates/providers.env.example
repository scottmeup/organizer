# Google OAuth and Google service integration
GOOGLE_CLIENT_ID=change_me
GOOGLE_CLIENT_SECRET=change_me
GOOGLE_REDIRECT_URI=https://andrewjscott.net/ui/oauth/google/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/calendar.events
GOOGLE_TASKS_SCOPES=https://www.googleapis.com/auth/tasks
GOOGLE_KEEP_SCOPES=https://www.googleapis.com/auth/keep

# Home Assistant integration
HOME_ASSISTANT_BASE_URL=http://home-assistant:8123
HOME_ASSISTANT_TOKEN=change_me
HOME_ASSISTANT_BRING_TODO_ENTITY=todo.shopping_list
HOME_ASSISTANT_PRESENCE_ENTITY=binary_sensor.office_presence
HOME_ASSISTANT_ALEXA_NOTIFY_SERVICE=notify.alexa_media

# Alexa custom skill
ALEXA_SKILL_APPLICATION_ID=change_me
ALEXA_SHARED_SECRET=change_me

# Bring direct credentials
BRING_EMAIL=change_me
BRING_PASSWORD=change_me
BRING_USE_HOME_ASSISTANT=true

# Display settings
DISPLAY_DEFAULT_PROFILE=default
DISPLAY_REFRESH_SECONDS=300
